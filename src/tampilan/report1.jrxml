	<parameter name="id_nota" class="java.lang.String"/>
	<queryString>
		<![CDATA[SELECT * FROM nota 
INNER JOIN isi ON nota.idnota = isi.idnota 
INNER JOIN pelanggan ON nota.id_pelanggan = pelanggan.id_pelanggan
WHERE nota.idnota=$P{id_nota}
]]>
	</queryString>
